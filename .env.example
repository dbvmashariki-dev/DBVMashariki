# =============================================================================
# DBV Mashariki — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL connection string (required)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# On Railway: this is automatically injected when you attach a Postgres plugin.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/dbvmashariki

# -----------------------------------------------------------------------------
# JWT secret — used to sign and verify authentication tokens.
# Use a long, random string in production (e.g. `openssl rand -hex 64`).
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-secret

# -----------------------------------------------------------------------------
# CORS origin — the URL(s) allowed to call the API.
# Use "*" to allow all origins (fine for development, not recommended in prod).
# For production set this to your frontend domain, e.g. https://dbvmashariki.com
# -----------------------------------------------------------------------------
CORS_ORIGIN=*

# -----------------------------------------------------------------------------
# Server port (optional — defaults to 5000)
# -----------------------------------------------------------------------------
PORT=5000

# -----------------------------------------------------------------------------
# Node environment
# -----------------------------------------------------------------------------
NODE_ENV=development
